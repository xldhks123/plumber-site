---
import { areas } from "../data/areas.js";

const phone = "1660-4350";
const tel = "16604350";

const mainAreas = areas.slice(0, 36);

const popularLinks = [];
for (const area of areas.slice(0, 20)) {
  for (const service of ["누수탐지", "하수구막힘", "싱크대막힘", "변기막힘"]) {
    popularLinks.push({ area, service });
  }
}
---

<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <title>배관솔루션 | 서울 누수탐지 하수구막힘 배관설비</title>
  <meta name="description" content="서울 전지역 누수탐지, 하수구막힘, 싱크대막힘, 변기막힘, 배관공사 상담 안내. 배관솔루션에서 지역별 배관 문제를 확인하세요." />
  <meta name="google-site-verification" content="ufxbHP5poCiOJo19nYHzIc6IcPAwYCUpgm6wioCrmm0" />
  <meta name="naver-site-verification" content="8d466ea3b0b71e22dd8804c9fda3b457eb162714" />

  <style>
    *{box-sizing:border-box}
    body{margin:0;font-family:Arial,'Noto Sans KR',sans-serif;color:#111;background:#fff}
    a{text-decoration:none;color:inherit}
    .topNotice{background:#063f9e;color:#fff;text-align:center;font-weight:900;padding:12px 10px;font-size:18px}
    .header{height:135px;background:#fff;display:flex;align-items:center;justify-content:center;border-bottom:1px solid #eee}
    .headInner{width:1180px;display:flex;align-items:center;justify-content:space-between}
    .brand{display:flex;flex-direction:column;gap:12px}
    .logo{font-size:34px;font-weight:900;color:#0646a8}
    .logo:before{content:"🔧";margin-right:10px}
    .headPhone{background:#1f5bbb;color:#fff;border-radius:999px;padding:16px 34px;font-size:26px;font-weight:900;display:inline-block}
    .nav{display:flex;gap:34px;font-size:18px;font-weight:900}

    .hero{display:grid;grid-template-columns:1fr 1fr;min-height:640px}
    .heroPhoto{background:linear-gradient(135deg,#ddd,#aaa);display:flex;align-items:center;justify-content:center;font-size:34px;font-weight:900;color:#fff}
    .heroBlue{background:#073f9e;color:#fff;display:flex;align-items:center;justify-content:center;padding:60px}
    .heroBox{text-align:center}
    .hand{color:#ffd000;font-size:30px;font-weight:900;margin-bottom:24px}
    h1{font-size:64px;line-height:1.18;margin:0;font-weight:900}
    .yellow{color:#ffd000}
    .bigCall{display:inline-block;margin-top:34px;background:#fff;color:#111;border-radius:999px;padding:22px 62px;font-size:44px;font-weight:900;box-shadow:0 12px 0 rgba(0,0,0,.18)}
    .miniText{margin-top:36px;color:#fff;font-size:24px;line-height:1.5}

    section{padding:80px 24px}
    .wrap{max-width:1180px;margin:0 auto}
    .center{text-align:center}
    h2{font-size:42px;margin:0 0 20px;font-weight:900}
    h2 span{color:#1f5bbb}
    .sub{font-size:20px;line-height:1.7;color:#222;margin:0}

    .cards3{display:grid;grid-template-columns:repeat(3,1fr);gap:26px;margin-top:46px}
    .card{border:1px solid #ddd;background:#fff;text-align:center}
    .fakeImg{height:210px;background:linear-gradient(135deg,#d8d8d8,#9d9d9d);display:flex;align-items:center;justify-content:center;color:white;font-size:26px;font-weight:900}
    .cardBody{padding:34px 28px}
    .card h3{color:#1f5bbb;font-size:24px;margin:0 0 18px}
    .card p{font-size:17px;line-height:1.75;margin:0;color:#222}

    .faqSec{display:grid;grid-template-columns:.9fr 1.1fr;gap:70px;align-items:center}
    .roundPhoto{height:560px;border-radius:90px;background:linear-gradient(135deg,#ddd,#999);display:flex;align-items:center;justify-content:center;color:white;font-size:30px;font-weight:900}
    .faqList{display:grid;gap:22px;margin-top:34px}
    .faqItem{background:#1f5bbb;color:#fff;border-radius:999px;padding:24px 36px;font-size:20px;font-weight:900;display:flex;justify-content:space-between}

    .midCall{padding:40px 24px;background:#f7f7f7}
    .midCallBox{max-width:900px;margin:auto;background:#1f5bbb;color:white;text-align:center;padding:42px;border-radius:26px;box-shadow:0 15px 40px rgba(0,0,0,.12)}
    .midSmall{font-size:26px;font-weight:900;margin-bottom:12px}
    .midPhone{display:inline-block;font-size:58px;font-weight:900;color:#ffd000;margin-bottom:16px}
    .midCallBox p{margin:0;font-size:20px;line-height:1.8}

    .works{background:#f7f7f7}
    .workGrid{display:grid;grid-template-columns:repeat(5,1fr);gap:22px;margin-top:44px}
    .workCard{background:#2464f2;color:#fff;height:180px;display:flex;align-items:center;justify-content:center;text-align:center;font-size:24px;font-weight:900}

    .serviceBand{display:grid;grid-template-columns:repeat(4,1fr)}
    .serviceItem{position:relative;min-height:380px;background:#111;color:#fff;padding:70px 50px;text-align:center;display:flex;flex-direction:column;justify-content:center;overflow:hidden}
    .serviceItem:before{content:"";position:absolute;inset:0;background:linear-gradient(rgba(0,0,0,.62),rgba(0,0,0,.72))}
    .serviceItem>*{position:relative}
    .num{font-size:54px;color:#ffd000;font-weight:900}
    .serviceItem h3{color:#ffd000;font-size:28px}
    .serviceItem p{font-size:18px;line-height:1.7;color:#ddd}

    .links{background:#fff}
    .areaGrid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-top:38px}
    .areaGrid a{border:1px solid #ddd;border-radius:12px;padding:16px 20px;font-weight:900}
    .popular{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-top:38px}
    .popular a{background:#f4f7ff;border:1px solid #dce6ff;border-radius:12px;padding:14px;font-weight:800;font-size:15px}

    .footer{background:#1f5bbb;color:#fff;text-align:center;padding:70px 24px}
    .footer h2{color:#fff}
    .footerCall{display:inline-block;margin-top:26px;color:#ffd000;font-size:34px;font-weight:900}

    @media(max-width:900px){
      .header{height:auto;padding:24px}
      .headInner,.hero,.faqSec,.cards3,.workGrid,.serviceBand,.areaGrid,.popular{grid-template-columns:1fr;display:grid}
      .headInner{gap:22px}
      .nav{display:none}
      h1{font-size:42px}
      .bigCall{font-size:30px;padding:18px 34px}
      .heroBlue{padding:50px 20px}
      .heroPhoto{min-height:300px}
      .midPhone{font-size:40px}
      .midSmall{font-size:21px}
      .midCallBox p{font-size:17px}
    }
  </style>
</head>

<body>
  <div class="topNotice">연중무휴 24시간 365일 빠른 상담 가능!</div>

  <header class="header">
    <div class="headInner">
      <div class="brand">
        <a class="logo" href="/">배관솔루션</a>
        <a class="headPhone" href={`tel:${tel}`}>대표전화 {phone}</a>
      </div>
      <nav class="nav">
        <a href="#services">우리가 하는 일</a>
        <a href="#works">주요 서비스</a>
        <a href="#areas">서울 현장</a>
        <a href="#faq">상담문의</a>
      </nav>
    </div>
  </header>

  <main>
    <section class="hero">
      <div class="heroPhoto">현장 상담 이미지</div>
      <div class="heroBlue">
        <div class="heroBox">
          <div class="hand">하수구막힘 | 싱크대막힘 | 누수탐지 | 배관공사</div>
          <h1>언제든 365일<br>빠른 상담 <span class="yellow">가능!</span></h1>
          <a class="bigCall" href={`tel:${tel}`}>☎ {phone}</a>
          <div class="miniText">막힘, 누수, 배관 문제로 걱정되신다면<br>증상 확인부터 차분하게 안내드립니다.</div>
        </div>
      </div>
    </section>

    <section>
      <div class="wrap center">
        <h2>배관솔루션은 <span>신뢰할 수 있는 안내</span>를 제공합니다.</h2>
        <p class="sub">상담부터 현장 확인, 문제 분석, 필요한 작업 안내까지 단계별로 도와드립니다.</p>

        <div class="cards3">
          <div class="card">
            <div class="fakeImg">상담 및 현장 확인</div>
            <div class="cardBody">
              <h3>상담 및 현장 미팅</h3>
              <p>증상을 먼저 듣고 현장 상황을 확인하여 문제의 원인을 차분하게 파악합니다.</p>
            </div>
          </div>
          <div class="card">
            <div class="fakeImg">장비 점검</div>
            <div class="cardBody">
              <h3>문제 분석과 안내</h3>
              <p>누수, 막힘, 역류 등 증상에 따라 필요한 확인 방법과 작업 범위를 안내합니다.</p>
            </div>
          </div>
          <div class="card">
            <div class="fakeImg">사후 관리</div>
            <div class="cardBody">
              <h3>재발 방지 안내</h3>
              <p>작업 후에도 같은 문제가 반복되지 않도록 관리 방법과 주의사항을 설명드립니다.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="faq">
      <div class="wrap faqSec">
        <div class="roundPhoto">싱크대 점검 이미지</div>
        <div>
          <h2>고객님들이 <span>자주 묻는 질문들</span></h2>
          <p class="sub">하수구, 싱크대, 변기, 누수 문제는 증상에 따라 원인이 다를 수 있습니다.</p>
          <div class="faqList">
            <a class="faqItem" href="/강남구-하수구막힘">하수구가 막혔을 때 거품이 나오는 이유는 무엇인가요? <b>+</b></a>
            <a class="faqItem" href="/강남구-싱크대막힘">싱크대 물이 늦게 빠지는 이유는 무엇인가요? <b>+</b></a>
            <a class="faqItem" href="/강남구-누수탐지">천장에 물자국이 생기면 누수인가요? <b>+</b></a>
          </div>
        </div>
      </div>
    </section>

    <section class="midCall">
      <div class="wrap">
        <div class="midCallBox">
          <div class="midSmall">📞 친절 상담 전화</div>
          <a class="midPhone" href={`tel:${tel}`}>{phone}</a>
          <p>
            누수탐지 · 하수구막힘 · 싱크대막힘 · 변기막힘<br />
            연중무휴 빠른 상담 가능
          </p>
        </div>
      </div>
    </section>

    <section id="works" class="works">
      <div class="wrap center">
        <h2>배관솔루션 <span>주요 서비스</span></h2>
        <p class="sub">서울 전지역 배관 문제를 지역별·서비스별로 확인할 수 있습니다.</p>

        <div class="workGrid">
          <a class="workCard" href="/강남구-누수탐지">강남구<br>누수탐지</a>
          <a class="workCard" href="/송파구-하수구막힘">송파구<br>하수구막힘</a>
          <a class="workCard" href="/서초구-싱크대막힘">서초구<br>싱크대막힘</a>
          <a class="workCard" href="/강동구-변기막힘">강동구<br>변기막힘</a>
          <a class="workCard" href="/마포구-배관공사">마포구<br>배관공사</a>
        </div>
      </div>
    </section>

    <section id="services" class="serviceBand">
      <a class="serviceItem" href="/강남구-하수구막힘">
        <div class="num">01</div>
        <h3>하수구 막힘 해결</h3>
        <p>물 빠짐 저하, 악취, 역류 증상을 확인하고 원인에 맞게 안내합니다.</p>
      </a>
      <a class="serviceItem" href="/강남구-싱크대막힘">
        <div class="num">02</div>
        <h3>싱크대 막힘 해결</h3>
        <p>기름때, 음식물 찌꺼기, 배관 내부 이물질로 인한 막힘을 확인합니다.</p>
      </a>
      <a class="serviceItem" href="/강남구-변기막힘">
        <div class="num">03</div>
        <h3>변기 막힘 해결</h3>
        <p>변기 물 차오름, 역류, 배수 불량 증상에 맞춰 점검합니다.</p>
      </a>
      <a class="serviceItem" href="/강남구-누수탐지">
        <div class="num">04</div>
        <h3>누수탐지 서비스</h3>
        <p>천장, 벽면, 장판 젖음 등 누수 의심 증상을 확인합니다.</p>
      </a>
    </section>

    <section id="areas" class="links">
      <div class="wrap center">
        <h2>서울 주요 지역 <span>바로가기</span></h2>
        <p class="sub">지역별 누수탐지 페이지로 이동할 수 있습니다.</p>
        <div class="areaGrid">
          {mainAreas.map((area) => (
            <a href={`/${area}-누수탐지`}>📍 {area} 누수탐지</a>
          ))}
        </div>
      </div>
    </section>

    <section class="links">
      <div class="wrap center">
        <h2>자주 찾는 <span>지역별 서비스</span></h2>
        <div class="popular">
          {popularLinks.map((item) => (
            <a href={`/${item.area}-${item.service}`}>{item.area} {item.service}</a>
          ))}
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <h2>배관솔루션</h2>
    <p>하수구막힘 · 싱크대막힘 · 변기막힘 · 누수탐지 · 배관공사 상담 안내</p>
    <a class="footerCall" href={`tel:${tel}`}>☎ {phone}</a>
  </footer>
</body>
</html>