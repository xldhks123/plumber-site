---
import { areas } from "../data/areas.js";
import { services } from "../data/services.js";

export async function getStaticPaths() {
  return areas.flatMap((area) =>
    services.map((service) => ({
      params: { slug: `${area}-${service}` },
      props: { area, service },
    }))
  );
}

const { area, service } = Astro.props;

const phone = "1660-4350";
const tel = "16604350";
const siteUrl = "https://eclectic-muffin-1e6f44.netlify.app";

const title = `${area} ${service} 전문 배관솔루션`;
const description = `${area} ${service} 문제 발생 시 현장 증상 확인부터 원인 진단, 필요한 작업 안내까지 배관솔루션에서 도와드립니다.`;
const canonicalUrl = `${siteUrl}/${area}-${service}`;

const areaIndex = areas.indexOf(area);
const serviceIndex = services.indexOf(service);

const leakServices = [
  "누수탐지","누수업체","누수진단","누수공사","아파트누수","빌라누수",
  "욕실누수","천장누수","수도누수","계량기돌아감","보일러젖음","장판젖음",
  "분배기누수","온수누수","변기누수","아랫집누수","배관누수"
];

const clogServices = [
  "하수구막힘","싱크대막힘","배수구막힘","배관막힘","배관뚫음","배관뚫기",
  "욕실막힘","화장실막힘","변기막힘","하수구역류","하수구뚫어주는곳",
  "싱크대뚫어주는곳","소변기막힘","세탁실막힘"
];

const pipeServices = ["배관청소","배관공사"];

let serviceType = "general";

if (leakServices.includes(service)) {
  serviceType = "leak";
} else if (clogServices.includes(service)) {
  serviceType = "clog";
} else if (pipeServices.includes(service)) {
  serviceType = "pipe";
}

function getAreaProfile(area) {
  if (area.includes("강남") || area.includes("서초") || area.includes("송파") || area.includes("잠실") || area.includes("대치") || area.includes("압구정") || area.includes("청담")) {
    return "아파트, 오피스텔, 상가 시설이 함께 많은 지역이라 배관 사용량이 많고 누수나 막힘 증상이 복합적으로 나타나는 경우가 있습니다.";
  }

  if (area.includes("마포") || area.includes("영등포") || area.includes("종로") || area.includes("중구") || area.includes("용산") || area.includes("성수") || area.includes("합정") || area.includes("서교")) {
    return "상가, 업무시설, 주거공간이 함께 있는 지역 특성상 배관 구조가 다양하고 사용 빈도에 따라 막힘이나 누수 증상이 다르게 나타날 수 있습니다.";
  }

  if (area.includes("강서") || area.includes("양천") || area.includes("구로") || area.includes("금천") || area.includes("관악") || area.includes("동작")) {
    return "빌라, 다세대주택, 아파트가 함께 있는 생활권이라 세대 내부 배관과 공용 배관 문제를 함께 확인해야 하는 경우가 많습니다.";
  }

  if (area.includes("노원") || area.includes("도봉") || area.includes("강북") || area.includes("중랑") || area.includes("성북") || area.includes("은평")) {
    return "오래된 주거시설과 아파트 단지가 함께 있는 지역이라 노후 배관, 배수 불량, 반복 막힘 증상을 세심하게 확인하는 것이 중요합니다.";
  }

  if (area.includes("강동") || area.includes("광진") || area.includes("성동") || area.includes("동대문")) {
    return "주거 밀집 지역과 상가 시설이 함께 분포한 곳이라 생활 배수 사용량이 많고 배관 내부 오염이나 누수 증상이 함께 확인되는 경우가 있습니다.";
  }

  return "주거시설과 생활 편의시설이 함께 있는 지역이라 배관 사용 환경에 따라 증상과 원인이 달라질 수 있습니다.";
}

const areaProfile = getAreaProfile(area);

const methods = ["배관 내시경 확인", "고압세척", "공압검사", "청음탐지", "가스탐지"];
const method = methods[(areaIndex + serviceIndex) % methods.length];

const serviceContents = {
  leak: {
    heading: `${area} ${service} 누수 원인 확인`,
    p1: `${area} ${service} 문제는 겉으로 보이는 물자국만 보고 판단하기 어려운 경우가 많습니다. ${areaProfile}`,
    p2: `천장 얼룩, 장판 젖음, 벽면 습기, 계량기 별침 회전처럼 증상은 비슷해 보여도 실제 원인은 수도배관, 온수배관, 난방배관, 욕실 방수층 등으로 달라질 수 있습니다.`,
    p3: `배관솔루션은 ${area} 현장에서 먼저 피해 위치와 물 사용 상황을 확인한 뒤 필요한 경우 ${method} 장비를 활용해 누수 가능성을 점검합니다.`
  },
  clog: {
    heading: `${area} ${service} 막힘 증상 점검`,
    p1: `${area} ${service} 문제는 음식물 찌꺼기, 기름때, 머리카락, 물티슈, 석회질, 오래된 배관 내부 이물질 등 여러 원인으로 발생할 수 있습니다. ${areaProfile}`,
    p2: `처음에는 물이 조금 늦게 빠지는 정도로 시작되지만 시간이 지나면 악취, 역류, 반복 막힘으로 이어지는 경우가 많습니다.`,
    p3: `배관솔루션은 ${area} 현장에서 배수 속도와 막힘 위치를 먼저 확인한 뒤 필요한 경우 ${method} 작업을 통해 원인을 파악합니다.`
  },
  pipe: {
    heading: `${area} ${service} 배관 상태 확인`,
    p1: `${area} ${service} 작업은 단순 수리가 아니라 배관 상태와 사용 환경을 함께 보는 것이 중요합니다. ${areaProfile}`,
    p2: `오래된 배관, 반복되는 막힘, 누수 흔적, 수압 저하, 악취 문제는 배관 내부 상태와 연결되어 있을 수 있습니다.`,
    p3: `배관솔루션은 ${area} 현장에서 배관 구조와 증상을 확인한 뒤 필요한 작업 범위를 안내합니다.`
  },
  general: {
    heading: `${area} ${service} 현장 안내`,
    p1: `${area} ${service} 문제는 단순히 한 가지 원인으로만 발생하지 않는 경우가 많습니다. ${areaProfile}`,
    p2: `배관 내부에 이물질이 쌓이거나 생활 오염물이 누적되면서 물 빠짐 저하, 악취, 습기, 반복 막힘 같은 증상이 함께 나타날 수 있습니다.`,
    p3: `배관솔루션은 ${area} ${service} 현장에서 먼저 증상을 확인한 뒤 필요한 작업 범위를 안내합니다.`
  }
};

const content = serviceContents[serviceType];

const relatedAreas = areas.filter((item) => item !== area).slice(areaIndex + 1, areaIndex + 9);
const relatedServices = services.filter((item) => item !== service).slice(serviceIndex + 1, serviceIndex + 7);
---

<html lang="ko">
<head>
  <meta charset="utf-8" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <style>
    *{box-sizing:border-box}
    body{margin:0;font-family:Arial,'Noto Sans KR',sans-serif;color:#071b3a;background:#f5f7fb}
    a{text-decoration:none;color:inherit}
    .top{background:#162b46;color:white;padding:18px 28px;display:flex;justify-content:space-between;align-items:center}
    .logo{font-size:22px;font-weight:900}
    .call{background:#ff5725;color:white;padding:12px 20px;border-radius:999px;font-weight:900}
    .hero{background:#102743;color:white;padding:70px 28px}
    .wrap{max-width:1080px;margin:0 auto}
    h1{font-size:52px;line-height:1.2;margin:0 0 20px;font-weight:900}
    .orange{color:#ff5725}
    section{padding:60px 28px}
    .box{background:white;border-radius:20px;padding:36px;border:1px solid #dde5ef;margin-bottom:24px}
    h2{font-size:32px;margin:0 0 20px}
    p{font-size:18px;line-height:1.85;color:#34445c}
    .grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px}
    .linkCard{background:white;border:1px solid #dde5ef;border-radius:14px;padding:18px;font-weight:900}
    .cta{background:#102743;color:white;text-align:center;padding:70px 28px}
    .cta h2{color:white}
    .cta p{color:#d7e2f1}
    .cta a{display:inline-block;margin-top:20px;background:#ff5725;color:white;padding:18px 34px;border-radius:14px;font-size:22px;font-weight:900}
    @media(max-width:800px){
      h1{font-size:36px}
      .grid{grid-template-columns:1fr}
    }
  </style>
</head>

<body>
  <header class="top">
    <a class="logo" href="/">배관솔루션</a>
    <a class="call" href={`tel:${tel}`}>📞 {phone}</a>
  </header>

  <main>
    <section class="hero">
      <div class="wrap">
        <h1>{area} <span class="orange">{service}</span></h1>
        <p>{description}</p>
      </div>
    </section>

    <section>
      <div class="wrap">
        <div class="box">
          <h2>{content.heading}</h2>
          <p>{content.p1}</p>
          <p>{content.p2}</p>
          <p>{content.p3}</p>
        </div>

        <div class="box">
          <h2>{area} 주변 상담 가능 지역</h2>
          <div class="grid">
            {relatedAreas.map((relatedArea) => (
              <a class="linkCard" href={`/${relatedArea}-${service}`}>{relatedArea} {service}</a>
            ))}
          </div>
        </div>

        <div class="box">
          <h2>함께 확인하는 서비스</h2>
          <div class="grid">
            {relatedServices.map((relatedService) => (
              <a class="linkCard" href={`/${area}-${relatedService}`}>{area} {relatedService}</a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="cta">
      <div class="wrap">
        <h2>{area} {service} 상담이 필요하신가요?</h2>
        <p>증상을 말씀해주시면 현장 상황에 맞춰 안내드립니다.</p>
        <a href={`tel:${tel}`}>📞 {phone}</a>
      </div>
    </section>
  </main>
</body>
</html>