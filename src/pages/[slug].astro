---
import { areas } from "../data/areas.js";
import { services } from "../data/services.js";

export async function getStaticPaths() {
  return areas.flatMap((area) =>
    services.map((service) => ({
      params: { slug: `${area}-${service}` },
      props: { area, service },
    }))
  );
}

const { area, service } = Astro.props;

const phone = "1660-4350";
const tel = "16604350";
const siteUrl = "https://eclectic-muffin-1e6f44.netlify.app";

const title = `${area} ${service} 전문 배관솔루션`;
const description = `${area} ${service} 문제 발생 시 현장 증상 확인부터 원인 진단, 필요한 작업 안내까지 배관솔루션에서 도와드립니다.`;
const canonicalUrl = `${siteUrl}/${area}-${service}`;

const areaIndex = areas.indexOf(area);
const serviceIndex = services.indexOf(service);

const areaTypes = [
  "아파트와 빌라가 함께 있는 지역 특성상",
  "상가와 주거시설이 함께 밀집된 지역이라",
  "오래된 배관과 신축 건물이 함께 있는 지역이라",
  "생활 배수 사용량이 많은 지역 특성상",
];

const symptoms = [
  "물이 천천히 빠지는 증상",
  "악취가 올라오는 증상",
  "배수가 반복적으로 막히는 증상",
  "바닥이나 벽면에 습기가 보이는 증상",
];

const methods = [
  "배관 내시경 확인",
  "고압세척",
  "공압검사",
  "청음탐지",
  "가스탐지",
];

const areaType = areaTypes[areaIndex % areaTypes.length];
const symptom = symptoms[(areaIndex + serviceIndex) % symptoms.length];
const method = methods[(areaIndex + serviceIndex) % methods.length];

const relatedAreas = areas
  .filter((item) => item !== area)
  .slice(areaIndex + 1, areaIndex + 9);

const relatedServices = services
  .filter((item) => item !== service)
  .slice(serviceIndex + 1, serviceIndex + 7);

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `${area} ${service} 상담이 가능한가요?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `${area} ${service} 문제는 현장 증상에 따라 확인 후 안내 가능합니다.`
      }
    },
    {
      "@type": "Question",
      "name": `${service} 문제는 바로 해결해야 하나요?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `${service} 증상은 시간이 지나면 반복되거나 악화될 수 있어 초기에 원인을 확인하는 것이 좋습니다.`
      }
    }
  ]
};
---

<html lang="ko">
<head>
  <meta charset="utf-8" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <style>
    *{box-sizing:border-box}
    body{margin:0;font-family:Arial,'Noto Sans KR',sans-serif;color:#071b3a;background:#f5f7fb}
    a{text-decoration:none;color:inherit}
    .top{background:#162b46;color:white;padding:18px 28px;display:flex;justify-content:space-between;align-items:center}
    .logo{font-size:22px;font-weight:900}
    .call{background:#ff5725;color:white;padding:12px 20px;border-radius:999px;font-weight:900}
    .hero{background:#102743;color:white;padding:70px 28px}
    .wrap{max-width:1080px;margin:0 auto}
    .badge{display:inline-block;border:1px solid #ff5725;color:#ff9b7a;border-radius:999px;padding:10px 16px;font-weight:900;margin-bottom:24px}
    h1{font-size:52px;line-height:1.2;margin:0 0 20px;font-weight:900}
    .hero p{font-size:20px;color:#d7e2f1;line-height:1.7}
    .orange{color:#ff5725}
    section{padding:60px 28px}
    .box{background:white;border-radius:20px;padding:36px;border:1px solid #dde5ef;margin-bottom:24px}
    h2{font-size:32px;margin:0 0 20px}
    p{font-size:18px;line-height:1.85;color:#34445c}
    .grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px}
    .linkCard{background:white;border:1px solid #dde5ef;border-radius:14px;padding:18px;font-weight:900}
    .cta{background:#102743;color:white;text-align:center;padding:70px 28px}
    .cta h2{color:white}
    .cta p{color:#d7e2f1}
    .cta a{display:inline-block;margin-top:20px;background:#ff5725;color:white;padding:18px 34px;border-radius:14px;font-size:22px;font-weight:900}
    @media(max-width:800px){
      h1{font-size:36px}
      .grid{grid-template-columns:1fr}
      .top{padding:16px}
    }
  </style>
</head>

<body>
  <header class="top">
    <a class="logo" href="/">배관솔루션</a>
    <a class="call" href={`tel:${tel}`}>📞 {phone}</a>
  </header>

  <main>
    <section class="hero">
      <div class="wrap">
        <div class="badge">현장 증상 확인 후 안내</div>
        <h1>{area} <span class="orange">{service}</span></h1>
        <p>{description}</p>
      </div>
    </section>

    <section>
      <div class="wrap">
        <div class="box">
          <h2>{area} {service} 안내</h2>
          <p>
            {area} {service} 문제는 단순히 한 가지 원인으로만 발생하지 않는 경우가 많습니다.
            {areaType} 배관 내부에 이물질이 쌓이거나 기름때와 생활 오염물이 누적되면서
            {symptom}이 함께 나타날 수 있습니다.
          </p>
          <p>
            배관솔루션은 {area} {service} 현장에서 먼저 증상을 확인한 뒤,
            필요한 경우 {method} 장비를 활용해 원인을 파악합니다.
            무조건 큰 공사를 권하는 방식이 아니라 실제로 필요한 작업 범위를 확인한 뒤 안내합니다.
          </p>
          <p>
            특히 {service} 문제는 시간이 지나면 같은 증상이 반복될 수 있기 때문에
            초기에 원인을 확인하는 것이 중요합니다.
            {area} 지역에서 {service} 관련 상담이 필요하다면 현장 상황에 맞춰 안내합니다.
          </p>
        </div>

        <div class="box">
          <h2>{area} 주변 상담 가능 지역</h2>
          <div class="grid">
            {relatedAreas.map((relatedArea) => (
              <a class="linkCard" href={`/${relatedArea}-${service}`}>
                {relatedArea} {service}
              </a>
            ))}
          </div>
        </div>

        <div class="box">
          <h2>함께 확인하는 서비스</h2>
          <div class="grid">
            {relatedServices.map((relatedService) => (
              <a class="linkCard" href={`/${area}-${relatedService}`}>
                {area} {relatedService}
              </a>
            ))}
          </div>
        </div>

        <div class="box">
          <h2>자주 묻는 질문</h2>
          <p>
            <strong>Q. {area} {service} 상담이 가능한가요?</strong><br />
            A. 현장 증상에 따라 확인 후 안내 가능합니다.
          </p>
          <p>
            <strong>Q. {service} 문제는 바로 해결해야 하나요?</strong><br />
            A. 시간이 지나면 반복되거나 악화될 수 있어 초기에 원인을 확인하는 것이 좋습니다.
          </p>
        </div>
      </div>
    </section>

    <section class="cta">
      <div class="wrap">
        <h2>{area} {service} 상담이 필요하신가요?</h2>
        <p>증상을 말씀해주시면 현장 상황에 맞춰 안내드립니다.</p>
        <a href={`tel:${tel}`}>📞 {phone}</a>
      </div>
    </section>
  </main>
</body>
</html>