---
import { areas } from "../data/areas.js";
import { services } from "../data/services.js";

export async function getStaticPaths() {
  return areas.flatMap((area) =>
    services.map((service) => ({
      params: { slug: `${area}-${service}` },
      props: { area, service },
    }))
  );
}

const { area, service } = Astro.props;

const title = `${area} ${service} 전문 배관솔루션`;
const description = `${area} ${service} 문제 발생 시 배관솔루션에서 현장 증상 확인부터 원인 진단, 필요한 작업 안내까지 도와드립니다.`;

const areaTypes = [
  "아파트와 빌라가 함께 있는 지역 특성상",
  "상가와 주거시설이 함께 밀집된 지역이라",
  "오래된 배관과 신축 건물이 함께 있는 지역이라",
  "생활 배수 사용량이 많은 지역 특성상",
];

const symptoms = [
  "물이 천천히 빠지는 증상",
  "악취가 올라오는 증상",
  "배수가 반복적으로 막히는 증상",
  "바닥이나 벽면에 습기가 보이는 증상",
];

const methods = [
  "배관 내시경 확인",
  "고압세척",
  "공압검사",
  "청음탐지",
  "가스탐지",
];

const areaIndex = areas.indexOf(area);
const serviceIndex = services.indexOf(service);

const areaType = areaTypes[areaIndex % areaTypes.length];
const symptom = symptoms[(areaIndex + serviceIndex) % symptoms.length];
const method = methods[(areaIndex + serviceIndex) % methods.length];

const relatedAreas = areas
  .filter((item) => item !== area)
  .slice(0, 5);
---

<html lang="ko">
<head>
  <meta charset="utf-8" />
  <title>{title}</title>
  <meta name="description" content={description} />
</head>

<body>
  <h1>{area} {service}</h1>

  <p>
    {area} {service} 문제는 단순히 한 가지 원인으로만 발생하지 않는 경우가 많습니다.
    {areaType} 배관 내부에 이물질이 쌓이거나, 기름때와 생활 오염물이 누적되면서
    {symptom}이 함께 나타날 수 있습니다.
  </p>

  <p>
    배관솔루션은 {area} {service} 현장에서 먼저 증상을 확인한 뒤,
    필요한 경우 {method} 장비를 활용해 원인을 파악합니다.
    무조건 큰 공사를 권하는 방식이 아니라, 실제로 필요한 작업 범위를 확인한 뒤 안내합니다.
  </p>

  <p>
    특히 {service} 문제는 시간이 지나면 같은 증상이 반복될 수 있기 때문에
    초기에 원인을 확인하는 것이 중요합니다.
    {area} 지역에서 하수구막힘, 누수탐지, 싱크대막힘 관련 상담이 필요하다면
    현장 상황에 맞춰 안내해드립니다.
  </p>

  <h2>{area} 주변 상담 가능 지역</h2>
  <ul>
    {relatedAreas.map((relatedArea) => (
      <li>
        <a href={`/${relatedArea}-${service}`}>{relatedArea} {service}</a>
      </li>
    ))}
  </ul>

  <p>
    전화문의 : 010-0000-0000
  </p>
</body>
</html>