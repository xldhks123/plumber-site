---
import { areas } from "../data/areas.js";
import { services } from "../data/services.js";

const phone = "1660-4350";
const tel = "16604350";

const mainServices = [
  "누수탐지",
  "하수구막힘",
  "싱크대막힘",
  "변기막힘",
  "배관막힘",
  "욕실누수",
  "천장누수",
  "배관공사",
];

const mainAreas = areas.slice(0, 40);
const popularLinks = [];

for (const area of areas.slice(0, 25)) {
  for (const service of ["누수탐지", "하수구막힘", "싱크대막힘", "변기막힘"]) {
    popularLinks.push({ area, service });
  }
}
---

<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <title>배관솔루션 | 서울 누수탐지 하수구막힘 배관설비</title>
  <meta name="description" content="서울 전지역 누수탐지, 하수구막힘, 싱크대막힘, 변기막힘, 배관공사 상담 안내. 지역별 서비스 페이지를 확인하세요." />
  <meta name="google-site-verification" content="ufxbHP5poCiOJo19nYHzIc6IcPAwYCUpgm6wioCrmm0" />
  <meta name="naver-site-verification" content="8d466ea3b0b71e22dd8804c9fda3b457eb162714" />

  <style>
    *{box-sizing:border-box}
    body{margin:0;font-family:Arial,'Noto Sans KR',sans-serif;color:#071b3a;background:#f5f7fb}
    a{text-decoration:none;color:inherit}
    .top{height:72px;background:#162b46;color:#fff;display:flex;align-items:center;justify-content:space-between;padding:0 34px}
    .logo{font-size:30px;font-weight:900}
    .phone{background:#ff5725;color:#fff;padding:16px 28px;border-radius:999px;font-size:22px;font-weight:900}
    .hero{background:#102743;color:white;padding:90px 34px}
    .wrap{max-width:1180px;margin:0 auto}
    .badge{display:inline-block;border:1px solid #ff5725;color:#ff9b7a;border-radius:999px;padding:12px 18px;font-weight:900;margin-bottom:28px}
    h1{font-size:62px;line-height:1.18;margin:0 0 24px;font-weight:900}
    .orange{color:#ff5725}
    .hero p{font-size:22px;color:#d7e2f1;line-height:1.7}
    .btns{margin-top:38px;display:flex;gap:16px;flex-wrap:wrap}
    .btn{display:inline-block;padding:20px 34px;border-radius:14px;font-weight:900;font-size:18px}
    .orangeBtn{background:#ff5725;color:#fff}
    .darkBtn{border:1px solid #738198;background:rgba(255,255,255,.08);color:#fff}
    section{padding:70px 34px}
    .sectionWhite{background:#fff}
    .label{color:#ff5725;font-weight:900;letter-spacing:.08em}
    h2{font-size:40px;margin:16px 0 18px;font-weight:900}
    .sub{font-size:18px;color:#50627c;line-height:1.7}
    .cards{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;margin-top:36px}
    .card{background:white;border:1px solid #dde5ef;border-radius:18px;padding:28px}
    .card h3{font-size:22px;margin:0 0 12px}
    .card p{color:#50627c;line-height:1.7}
    .grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-top:34px}
    .linkCard{background:white;border:1px solid #dde5ef;border-radius:14px;padding:18px;font-weight:900}
    .linkCard:hover{border-color:#ff5725}
    .popular{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-top:34px}
    .popular a{background:#fff;border:1px solid #dde5ef;border-radius:12px;padding:14px;font-weight:800;font-size:15px}
    .faq{background:white;border:1px solid #dde5ef;border-radius:18px;padding:28px;margin-top:18px}
    .faq p{font-size:17px;line-height:1.75;color:#34445c}
    .cta{background:#102743;color:#fff;text-align:center;padding:80px 34px}
    .cta h2{color:#fff}
    .cta p{color:#d7e2f1;font-size:20px}
    .cta .phone{display:inline-block;margin-top:24px;border-radius:14px;padding:22px 46px;font-size:30px}
    @media(max-width:900px){
      .top{padding:0 18px}
      .logo{font-size:24px}
      .phone{font-size:18px;padding:12px 18px}
      h1{font-size:40px}
      .cards,.grid,.popular{grid-template-columns:1fr}
    }
  </style>
</head>

<body>
  <header class="top">
    <a class="logo" href="/">배관솔루션</a>
    <a class="phone" href={`tel:${tel}`}>📞 {phone}</a>
  </header>

  <main>
    <section class="hero">
      <div class="wrap">
        <div class="badge">서울 전지역 배관설비 상담</div>
        <h1>서울 누수탐지부터<br><span class="orange">하수구막힘까지</span></h1>
        <p>
          배관솔루션은 누수탐지, 하수구막힘, 싱크대막힘, 변기막힘, 배관공사 등
          생활 배관 문제를 지역별로 안내하는 배관 전문 서비스입니다.
        </p>
        <div class="btns">
          <a class="btn orangeBtn" href={`tel:${tel}`}>지금 전화하기</a>
          <a class="btn darkBtn" href="#services">서비스 보기</a>
          <a class="btn darkBtn" href="#areas">지역 보기</a>
        </div>
      </div>
    </section>

    <section id="services" class="sectionWhite">
      <div class="wrap">
        <div class="label">MAIN SERVICES</div>
        <h2>대표 배관 서비스</h2>
        <p class="sub">자주 찾는 배관 문제를 서비스별로 확인할 수 있습니다.</p>

        <div class="cards">
          {mainServices.map((service) => (
            <a class="card" href={`/강남구-${service}`}>
              <h3>{service}</h3>
              <p>서울 지역 {service} 관련 증상, 원인, 상담 가능 내용을 확인하세요.</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section id="areas">
      <div class="wrap">
        <div class="label">SERVICE AREA</div>
        <h2>주요 지역 바로가기</h2>
        <p class="sub">서울 주요 구와 동 단위 지역 페이지로 이동할 수 있습니다.</p>

        <div class="grid">
          {mainAreas.map((area) => (
            <a class="linkCard" href={`/${area}-누수탐지`}>
              {area} 누수탐지
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="sectionWhite">
      <div class="wrap">
        <div class="label">POPULAR LINKS</div>
        <h2>자주 찾는 지역별 서비스</h2>
        <p class="sub">검색 수요가 많은 누수탐지, 하수구막힘, 싱크대막힘, 변기막힘 페이지를 연결했습니다.</p>

        <div class="popular">
          {popularLinks.map((item) => (
            <a href={`/${item.area}-${item.service}`}>
              {item.area} {item.service}
            </a>
          ))}
        </div>
      </div>
    </section>

    <section>
      <div class="wrap">
        <div class="label">SEO GUIDE</div>
        <h2>배관 문제는 초기에 확인하는 것이 중요합니다</h2>

        <div class="faq">
          <p>
            누수탐지는 눈에 보이는 물자국만으로 원인을 판단하기 어렵습니다.
            천장누수, 욕실누수, 수도누수, 온수누수처럼 증상이 비슷해 보여도 실제 원인은 다를 수 있습니다.
          </p>
        </div>

        <div class="faq">
          <p>
            하수구막힘, 싱크대막힘, 변기막힘은 시간이 지나면 악취와 역류로 이어질 수 있습니다.
            배수 속도가 느려지거나 반복적으로 막힌다면 초기에 배관 상태를 확인하는 것이 좋습니다.
          </p>
        </div>

        <div class="faq">
          <p>
            배관솔루션은 서울 지역별 배관 문제를 쉽게 확인할 수 있도록 지역과 서비스별 안내 페이지를 제공합니다.
            원하는 지역과 증상에 맞는 페이지를 선택해 확인할 수 있습니다.
          </p>
        </div>
      </div>
    </section>

    <section class="cta">
      <div class="wrap">
        <h2>배관 문제가 있다면 바로 상담하세요</h2>
        <p>누수, 막힘, 역류, 배관공사까지 현장 상황에 맞춰 안내드립니다.</p>
        <a class="phone" href={`tel:${tel}`}>📞 {phone}</a>
      </div>
    </section>
  </main>
</body>
</html>